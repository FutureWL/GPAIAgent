generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String?    @unique
  name         String?
  avatar       String?
  bio          String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  passwordHash String
  username     String     @unique

  comments     Comment[]
  likes        Like[]
  strategies   Strategy[]
  stocks       UserStock[]
  membership    Membership?
  aiGenerations AIGeneration[]
  posts         Post[]
  postLikes     PostLike[]     @relation("PostLikeUser")
  postComments  PostComment[]  @relation("PostCommentUser")
  postBookmarks PostBookmark[] @relation("PostBookmarkUser")
}

model Stock {
  id        String   @id @default(cuid())
  code      String   @unique // 如 600519
  name      String             // 如 贵州茅台
  market    String             // sh / sz / bj
  type      String   @default("stock") // stock / bond / fund / index
  createdAt DateTime @default(now())

  userStocks UserStock[]
  strategies Strategy[]
  aiGenerations AIGeneration[]
}

model UserStock {
  id        String   @id @default(cuid())
  userId    String
  stockId   String
  addedAt   DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock     Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([userId, stockId])
}

enum MembershipLevel {
  NORMAL   // 普通会员
  PRIVATE  // 私人会员
}

enum MembershipType {
  TRIAL    // 体验卡（7天）
  MONTHLY  // 月卡
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
}

model Membership {
  id        String   @id @default(cuid())
  userId    String   @unique
  level     MembershipLevel
  type      MembershipType
  startedAt DateTime @default(now())
  expiredAt DateTime
  status    MembershipStatus @default(ACTIVE)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Strategy {
  id          String   @id @default(cuid())
  title       String
  description String
  content     String
  tags        String[]
  stockCode   String?  // 关联股票代码，可选
  riskLevel   String?  // risk_high / profit_high / neutral / avoid
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authorId    String

  backtests  Backtest[]
  comments   Comment[]
  likes      Like[]
  author     User      @relation(fields: [authorId], references: [id])
  stock      Stock?    @relation(fields: [stockCode], references: [code])
  aiGenerations AIGeneration[]
}

model Backtest {
  id         String   @id @default(cuid())
  name       String
  params     Json
  result     Json
  summary    String?
  createdAt  DateTime @default(now())
  strategyId String

  strategy   Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
}

model Comment {
  id         String   @id @default(cuid())
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  authorId   String
  strategyId String

  author     User     @relation(fields: [authorId], references: [id])
  strategy   Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
}

model Like {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String
  strategyId String

  strategy   Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, strategyId])
}

model AIGeneration {
  id         String   @id @default(cuid())
  userId     String
  stockCode  String?
  stockName  String?
  prompt     String
  result     String
  riskLevel  String?
  strategyId String?
  model      String   @default("MiniMax-Text-01")
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock      Stock?   @relation(fields: [stockCode], references: [code])
  strategy   Strategy? @relation(fields: [strategyId], references: [id])
}

// ============ 博客/帖子相关 ============

model Post {
  id          String   @id @default(cuid())
  title       String
  content     String
  excerpt     String?
  coverImage  String?
  type        String   @default("article") // article | video
  videoUrl    String?
  viewCount   Int      @default(0)
  likeCount   Int      @default(0)
  commentCount Int     @default(0)
  shareCount  Int      @default(0)
  status      String   @default("published") // published | draft
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes     PostLike[]     @relation("PostLikedBy")
  comments  PostComment[]  @relation("PostCommentPost")
  bookmarks PostBookmark[] @relation("PostBookmarkedBy")
}

model PostLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  postId    String

  post  Post  @relation("PostLikedBy", fields: [postId], references: [id], onDelete: Cascade)
  user  User  @relation("PostLikeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model PostComment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  postId    String

  post Post  @relation("PostCommentPost", fields: [postId], references: [id], onDelete: Cascade)
  user User @relation("PostCommentUser", fields: [userId], references: [id], onDelete: Cascade)
}

model PostBookmark {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  postId    String

  post Post  @relation("PostBookmarkedBy", fields: [postId], references: [id], onDelete: Cascade)
  user User @relation("PostBookmarkUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}
