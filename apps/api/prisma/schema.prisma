generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String?    @unique
  name         String?
  avatar       String?
  bio          String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  passwordHash String
  username     String     @unique
  comments     Comment[]
  likes        Like[]
  strategies   Strategy[]
}

model Strategy {
  id          String     @id @default(cuid())
  title       String
  description String
  content     String
  tags        String[]
  viewCount   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  authorId    String
  backtests   Backtest[]
  comments    Comment[]
  likes       Like[]
  author      User       @relation(fields: [authorId], references: [id])
}

model Backtest {
  id         String   @id @default(cuid())
  name       String
  params     Json
  result     Json
  summary    String?
  createdAt  DateTime @default(now())
  strategyId String
  strategy   Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
}

model Comment {
  id         String   @id @default(cuid())
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  authorId   String
  strategyId String
  author     User     @relation(fields: [authorId], references: [id])
  strategy   Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
}

model Like {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String
  strategyId String
  strategy   Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, strategyId])
}
