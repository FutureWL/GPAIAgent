generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String?    @unique
  name         String?
  avatar       String?
  bio          String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  passwordHash String
  username     String     @unique

  comments     Comment[]
  likes        Like[]
  strategies   Strategy[]
  stocks       UserStock[]
  membership    Membership?
  aiGenerations AIGeneration[]
  stockScreens  StockScreen[]
  posts         Post[]
  postLikes     PostLike[]     @relation("PostLikeUser")
  postComments  PostComment[]  @relation("PostCommentUser")
  postBookmarks PostBookmark[] @relation("PostBookmarkUser")
}

model Stock {
  id        String   @id @default(cuid())
  code      String   @unique // 如 600519
  name      String             // 如 贵州茅台
  market    String             // sh / sz / bj
  type      String   @default("stock") // stock / bond / fund / index
  createdAt DateTime @default(now())

  userStocks    UserStock[]
  dailyData     StockDaily[]
  periodKlines  StockPeriodKline[]
  quotes        StockQuote[]
  strategies    Strategy[]
  aiGenerations AIGeneration[]
  stockScreenResults StockScreenResult[]
}

model UserStock {
  id        String   @id @default(cuid())
  userId    String
  stockId   String
  addedAt   DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock     Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([userId, stockId])
}

model StockDaily {
  id        String   @id @default(cuid())
  stockId   String
  date      DateTime @db.Date  // 交易日期
  open      Float             // 开盘价（前复权）
  close     Float             // 收盘价（前复权）
  high      Float             // 最高价
  low       Float             // 最低价
  volume    Float             // 成交量（手）
  amount    Float             // 成交额（元）
  createdAt DateTime @default(now())

  stock     Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, date])
  @@index([date])
}

// 多周期K线（周/月/季/年及分钟K线，用于缓存和离线访问）
// 日K用 StockDaily，分钟K线(1/5/15/30/60min)用此表
model StockPeriodKline {
  id        String   @id @default(cuid())
  stockId   String
  period    String              // day | week | month | season | year | 1min | 5min | 15min | 30min | 60min
  date      DateTime @db.Date  // 对日K是日期，对分钟K线是"YYYY-MM-DD"（时间部分忽略）
  open      Float
  close     Float
  high      Float
  low       Float
  volume    Float
  createdAt DateTime @default(now())

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, period, date])
  @@index([stockId, period])
  @@index([date])
}

enum MembershipLevel {
  NORMAL   // 普通会员
  PRIVATE  // 私人会员
}

enum MembershipType {
  TRIAL    // 体验卡（7天）
  MONTHLY  // 月卡
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
}

model Membership {
  id        String   @id @default(cuid())
  userId    String   @unique
  level     MembershipLevel
  type      MembershipType
  startedAt DateTime @default(now())
  expiredAt DateTime
  status    MembershipStatus @default(ACTIVE)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Strategy {
  id          String   @id @default(cuid())
  title       String
  description String
  content     String
  tags        String[]
  stockCode   String?  // 关联股票代码，可选
  riskLevel   String?  // risk_high / profit_high / neutral / avoid
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authorId    String

  backtests  Backtest[]
  comments   Comment[]
  likes      Like[]
  author     User      @relation(fields: [authorId], references: [id])
  stock      Stock?    @relation(fields: [stockCode], references: [code])
  aiGenerations AIGeneration[]
}

model Backtest {
  id         String   @id @default(cuid())
  name       String
  params     Json
  result     Json
  summary    String?
  createdAt  DateTime @default(now())
  strategyId String

  strategy   Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
}

model Comment {
  id         String   @id @default(cuid())
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  authorId   String
  strategyId String

  author     User     @relation(fields: [authorId], references: [id])
  strategy   Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
}

model Like {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String
  strategyId String

  strategy   Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, strategyId])
}

model AIGeneration {
  id         String   @id @default(cuid())
  userId     String
  stockCode  String?
  stockName  String?
  prompt     String
  result     String
  riskLevel  String?
  strategyId String?
  model      String   @default("MiniMax-Text-01")
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock      Stock?   @relation(fields: [stockCode], references: [code])
  strategy   Strategy? @relation(fields: [strategyId], references: [id])
}

// ============ 博客/帖子相关 ============

model Post {
  id          String   @id @default(cuid())
  title       String
  content     String
  excerpt     String?
  coverImage  String?
  type        String   @default("article") // article | video
  videoUrl    String?
  viewCount   Int      @default(0)
  likeCount   Int      @default(0)
  commentCount Int     @default(0)
  shareCount  Int      @default(0)
  status      String   @default("published") // published | draft
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes     PostLike[]     @relation("PostLikedBy")
  comments  PostComment[]  @relation("PostCommentPost")
  bookmarks PostBookmark[] @relation("PostBookmarkedBy")
}

model PostLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  postId    String

  post  Post  @relation("PostLikedBy", fields: [postId], references: [id], onDelete: Cascade)
  user  User  @relation("PostLikeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model PostComment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  postId    String

  post Post  @relation("PostCommentPost", fields: [postId], references: [id], onDelete: Cascade)
  user User @relation("PostCommentUser", fields: [userId], references: [id], onDelete: Cascade)
}

model PostBookmark {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  postId    String

  post Post  @relation("PostBookmarkedBy", fields: [postId], references: [id], onDelete: Cascade)
  user User @relation("PostBookmarkUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

// ============ 市场数据同步队列（数据库-backed） ============

// 同步任务类型
enum SyncTaskType {
  REALTIME_QUOTE   // 实时行情（每分钟）
  DAILY_KLINE      // 日K线（每日收盘后）
  PERIOD_KLINE     // 多周期K线（周/月/季/年，每日收盘后）
  MINUTE_KLINE     // 分钟K线（交易时段每15分钟）
}

// 同步任务状态
enum SyncTaskStatus {
  PENDING   // 待处理
  PROCESSING // 处理中
  COMPLETED // 完成
  FAILED    // 失败（已达最大重试次数）
}

model SyncQueue {
  id          String   @id @default(cuid())
  type        SyncTaskType
  target      String   // 股票代码，如 "600519"，或 "ALL"
  period      String? // K线周期，如 "day","week","1min"，可选
  priority    Int      @default(0)  // 越大越优先
  retries     Int      @default(0)  // 已重试次数
  maxRetries  Int      @default(3)  // 最大重试次数
  status      SyncTaskStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, priority])
  @@index([type, target])
}

// 同步任务执行记录
enum SyncJobStatus {
  SUCCESS
  FAILURE
  PARTIAL  // 部分成功（如批量中某些失败）
}

model SyncJob {
  id          String   @id @default(cuid())
  queueId     String?  // 对应的 SyncQueue id（可选，无队列的直接任务）
  type        SyncTaskType
  target      String   // 股票代码或 "ALL"
  period      String?  // K线周期
  status      SyncJobStatus
  itemsTotal  Int      @default(0)  // 处理总条数
  itemsOk     Int      @default(0)  // 成功条数
  errorMsg    String?  // 错误信息
  durationMs  Int?     // 耗时（毫秒）
  startedAt   DateTime @default(now())
  completedAt DateTime?

  @@index([type, startedAt])
  @@index([target])
}

// 实时行情快照（每小时刷新）
model StockQuote {
  id         String   @id @default(cuid())
  stockId    String
  price      Float              // 现价
  change     Float              // 涨跌额
  changePct  Float              // 涨跌幅 %
  open       Float              // 开盘价
  high       Float              // 最高价
  low        Float              // 最低价
  volume     Float              // 成交量（手）
  amount     Float              // 成交额（元）
  turnover   Float?             // 换手率 %
  preClose   Float              // 前收盘
  marketCap  Float?             // 总市值（元）
  circulateCap Float?            // 流通市值（元）
  netInflow  Float?             // 净流入（元）
  capturedAt DateTime @default(now()) // 快照时间

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, capturedAt])
  @@index([stockId, capturedAt])
  @@index([capturedAt])
}

// ============ 选股相关 ============

model StockScreen {
  id               String   @id @default(cuid())
  userId           String
  title            String
  description      String?
  criteria         Json              // 筛选条件
  aiRecommendation String?           // AI 补充建议
  riskLevel        String?           // risk_high / profit_high / neutral / avoid
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  results StockScreenResult[]
}

model StockScreenResult {
  id        String   @id @default(cuid())
  screenId  String
  stockId   String
  rank      Int      @default(0)
  aiComment String?  // AI 针对此股票的简要点评
  createdAt DateTime @default(now())

  screen StockScreen @relation(fields: [screenId], references: [id], onDelete: Cascade)
  stock  Stock       @relation(fields: [stockId], references: [id])

  @@unique([screenId, stockId])
}
