{
  "name": "gpaiagent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:api": "dotenv -e apps/api/.env.dev -- pnpm --filter @gpaiagent/api dev",
    "dev:web": "dotenv -e apps/web/.env.dev -- pnpm --filter @gpaiagent/web dev",
    "dev:db:push": "dotenv -e apps/api/.env.dev -- pnpm --filter @gpaiagent/api db:push",
    "dev:db:studio": "dotenv -e apps/api/.env.dev -- pnpm --filter @gpaiagent/api db:studio",
    "dev:db:generate": "dotenv -e apps/api/.env.dev -- pnpm --filter @gpaiagent/api db:generate",
    "prod:api": "dotenv -e apps/api/.env.prod -- pnpm --filter @gpaiagent/api start",
    "prod:web": "dotenv -e apps/web/.env.prod -- pnpm --filter @gpaiagent/web start",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "db:push:dev": "dotenv -e apps/api/.env.dev -- pnpm --filter @gpaiagent/api db:push",
    "db:push:prod": "dotenv -e apps/api/.env.prod -- pnpm --filter @gpaiagent/api db:push",
    "db:generate:dev": "dotenv -e apps/api/.env.dev -- pnpm --filter @gpaiagent/api db:generate"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.1.1"
    }
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
